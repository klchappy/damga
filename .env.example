# =============================================
# Damga — Environment Variables (root)
# Copy to .env, fill in real values
# =============================================

# --- Runtime ---
NODE_ENV=development
PORT=4100
WEB_PORT=5273
CLIENT_URL=http://localhost:5273
SERVER_URL=http://localhost:4100

# --- Supabase (Postgres + Auth) ---
SUPABASE_URL=https://YOUR-DAMGA-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Database (Drizzle / Postgres) ---
# Lokal dev için Docker compose Postgres:
DATABASE_URL=postgres://damga:damga@localhost:5433/damga
DIRECT_URL=postgres://damga:damga@localhost:5433/damga

# --- Redis (Upstash veya lokal) ---
REDIS_URL=redis://localhost:6380
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxx
EMAIL_FROM=Damga <noreply@damga.deploi.net>

# --- NFC Tag Signature Secret ---
# NFC tag'lara basılı imzaları doğrulamak için HMAC secret'ı
NFC_SIGNING_SECRET=change-this-to-a-strong-secret-min-32-chars

# --- Rate Limit ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# --- Vite (web tarafı) ---
VITE_API_URL=http://localhost:4100
VITE_SUPABASE_URL=https://YOUR-DAMGA-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxx

# --- Iyzico (Faz 9 — şimdilik boş) ---
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# --- Sentry (Faz 10) ---
SENTRY_DSN=
